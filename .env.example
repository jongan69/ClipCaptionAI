OPENAI_API_KEY=sk-your-openai-key-here

# Optional. Enables YouTube Data API search for stronger B-roll discovery.
YOUTUBE_API_KEY=

# Optional. Transcription backend preference:
# auto | local-whispercpp | openai | youtube
TRANSCRIBE_PROVIDER=local-whispercpp

# Optional. whisper.cpp local model alias or full path.
# Good aliases: tiny.en, base.en, small.en, medium.en
WHISPER_CPP_MODEL=small.en

# Optional. Clean up local/youtube transcripts with a cheap OpenAI text model.
OPENAI_TEXT_ANALYSIS_MODEL=gpt-4.1-mini

# Optional. Local-only ElevenLabs narration. Never commit your real .env file.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Optional. Local-only fal provider key for reviewed GPT Image 2 edits and Veo 3.1 proofs.
# Never expose this to the Electron renderer or commit it.
FAL_KEY=
