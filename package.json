    "commander": "^15.0.0",
    "dotenv": "16.4.7",
    "openai": "5.7.0",
    "picocolors": "^1.1.1",
    "remotion": "4.0.481",
    "tsx": "4.20.3"
  },
  "devDependencies": {
    "@types/node": "24.0.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "typescript": "5.8.3"
  }
